#Step 1 — Install the gateway:

pkg update && pkg upgrade -y

#Step 2 — Unlock the graphical system:

pkg install x11-repo
pkg install termux-x11-nightly xfce4

#Step 3 — Start the desktop universe:

termux-x11 :0 -xstartup "dbus-launch --exit-with-session xfce4-session"


#Then you open Termux X11, and suddenly your Android screen transforms into a full XFCE Linux desktop.